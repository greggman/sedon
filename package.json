{
  "name": "sedon",
  "version": "0.0.1",
  "description": "Generate 3D content from procedural node graphs",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node scripts/build.mjs --serve --prod",
    "devd": "node scripts/build.mjs --serve",
    "build": "node scripts/build.mjs",
    "test": "npm run test:unit && npm run test:browser",
    "test:unit": "node --import tsx --import ./scripts/test-bootstrap.mjs --test \"test/unit/**/*.test.ts\"",
    "test:browser": "node --import tsx --import ./scripts/test-bootstrap.mjs --test test/browser/ux.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/showdown": "^2.0.6",
    "@webgpu/types": "^0.1.40",
    "esbuild": "^0.20.0",
    "puppeteer": "^25.0.2",
    "showdown": "^2.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "dockview": "^6.2.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  }
}
